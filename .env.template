# IkigaiTradeOS Market Intelligence — Environment Variables Template
# Copy this file to .env and fill in your values.
# See LOCAL_SETUP.md for full instructions.

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# MySQL connection string (local or cloud)
DATABASE_URL=mysql://root:YOUR_PASSWORD@localhost:3306/ikigai_trade_os

# Random 32+ char secret for session cookies
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET

# ── AUTHENTICATION (Manus OAuth) ───────────────────────────────────────────────
# Required for the Upload Positions page login.
# Skip by changing protectedProcedure → publicProcedure in server/routers.ts
VITE_APP_ID=
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im
OWNER_OPEN_ID=
OWNER_NAME=

# ── MANUS BUILT-IN APIs (Optional) ────────────────────────────────────────────
# Only needed for LLM analysis and S3 file storage features.
# Core dashboard and CSV upload work without these.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ── COSMETIC (Optional) ────────────────────────────────────────────────────────
VITE_APP_TITLE=IkigaiTradeOS Market Intelligence
VITE_APP_LOGO=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── UNIFIED TRADING PLATFORM (UTP) BACKEND ────────────────────────────────────
# Base URL of the Python FastAPI engine that powers /engines, /helios, etc.
# Local dev: http://localhost:8000
# Production: https://trading.ikigaios.com
# If unset, the client defaults to http://localhost:8000.
# CORS: UTP must allow this site's origin in backend/api/app.py CORSMiddleware.
VITE_UTP_BASE_URL=http://localhost:8000

# Bearer token sent as Authorization header to UTP. Phase A bootstrap is a
# shared secret matched by UTP's AuthMiddleware. Phase A.4 replaces this
# with a proper JWT issued post-OAuth. Empty in dev = unauthenticated calls.
VITE_UTP_API_KEY=
