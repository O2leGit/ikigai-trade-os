# IkigaiTradeOS Market Intelligence — Environment Variables Template
# Copy this file to .env and fill in your values.
# See LOCAL_SETUP.md for full instructions.
#
# Variables WITHOUT a VITE_ prefix are server-side only (Netlify Functions) and
# are never exposed to the browser. Variables WITH a VITE_ prefix are inlined
# into the client bundle at build time — never put secrets in those.

# ── NETLIFY FUNCTION SECRETS (server-side) ────────────────────────────────────
# LLM key for AI briefing/position analysis (ai-chat, *-briefing, analyze-* fns).
ANTHROPIC_API_KEY=
# Market/news data providers used by the news + market-data functions.
FINNHUB_KEY=
MARKETAUX_KEY=

# ── SAVE-ACCOUNTS AUTH (server-side) ──────────────────────────────────────────
# The save-accounts function verifies the caller's UTP session by calling an
# auth-gated UTP endpoint with the caller's bearer (200 = valid, 401 = reject).
# UTP origin the function calls (server-side; separate from VITE_UTP_BASE_URL).
UTP_BASE_URL=https://trading.ikigaios.com
# Auth-gated UTP GET used purely to validate the bearer.
UTP_VERIFY_PATH=/api/engines
# Enforcement is ON unless set to "false". Set to "false" for local dev
# (netlify dev), where there is no UTP session to present.
REQUIRE_UPLOAD_AUTH=true

# ── UNIFIED TRADING PLATFORM (UTP) BACKEND ────────────────────────────────────
# Base URL of the Python FastAPI engine that powers /engines, /helios, etc.
# Local dev: http://localhost:8000   Production: https://trading.ikigaios.com
# If unset, the client defaults to http://localhost:8000.
# CORS: UTP must allow this site's origin in its CORSMiddleware.
VITE_UTP_BASE_URL=http://localhost:8000
# Bearer token sent as the Authorization header to UTP. Empty in dev =
# unauthenticated calls.
VITE_UTP_API_KEY=

# ── LEGACY OAUTH / FORGE (client, optional) ───────────────────────────────────
# Still referenced by the client login helper. Leave blank to disable.
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=https://manus.im
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ── COSMETIC (Optional) ───────────────────────────────────────────────────────
VITE_APP_TITLE=ikigaiOS Trading
VITE_APP_LOGO=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
