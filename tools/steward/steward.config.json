{
  "version": 1,
  "defaults": {
    "watchFraction": 0.8,
    "autoApply": ["index_row", "raw_cache", "freshness_flag", "heartbeat", "telemetry", "digest_draft"],
    "gate": ["facts_edit", "decision_edit", "glossary_edit", "client_comms", "supersede", "prompt_change"],
    "never": ["money", "customer_price", "mrp_execute", "agent_authority_change", "outbound_send"]
  },
  "projects": {
    "palletone": {
      "name": "PalletOne SE Decision Sprint",
      "memoryRepo": "palletone-engagement",
      "manifest": "records/transcripts/INDEX.md",
      "owners": { "default": "chris@cotoole.com", "finance": "Finance", "data": "kchamp@ufpi.com" },
      "sources": [
        { "id": "ufp-share", "kind": "drive_folder", "label": "KonsProjectShares/PalletOneShare", "slaHours": 26, "confidential": "client" },
        { "id": "transcripts", "kind": "gdoc", "label": "PalletOne meeting transcripts", "slaHours": 96, "confidential": "client" },
        { "id": "palletone-email", "kind": "gmail", "query": "from:ccupoli@palletone.com OR from:kchamp@ufpi.com newer_than:14d", "slaHours": 96, "confidential": "client" }
      ]
    }
  }
}
